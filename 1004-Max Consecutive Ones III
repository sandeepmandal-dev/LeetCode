/*
Approach
Used the Variable-Size Sliding Window technique.
Expanded the window by moving the right pointer.
Counted the number of 0s in the current window.
Shrank the window whenever the number of 0s exceeded k.
Tracked the maximum valid window length.

Time Complexity: O(n)
Space Complexity: O(1)
*/
class Solution {
    public int longestOnes(int[] nums, int k) {
        int left =0;
        int zeroCount=0;
        int maxLength=0;

        for(int right=0; right<nums.length; right++){
            
            if(nums[right]==0){
                zeroCount++;
            }

            while(zeroCount>k){
                if(nums[left]==0){
                    zeroCount--;
                }
                left++;
            }
            maxLength = Math.max(maxLength, right - left + 1);
        }
        return maxLength;
    }
}